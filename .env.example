# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional ──────────────────────────────────────────────────────────────────
# Shared secret GHL sends in the x-webhook-secret header to lock the endpoint
GHL_WEBHOOK_SECRET=your-secret-here

# GHL inbound webhook URL — fires when Claude finds issues with an event
# Set up a GHL workflow: trigger = Inbound Webhook → action = notify admin
ADMIN_NOTIFY_WEBHOOK_URL=https://services.leadconnectorhq.com/hooks/...
